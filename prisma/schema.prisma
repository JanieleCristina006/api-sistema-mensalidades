generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PlanStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum SignatureStatus {
  ACTIVE
  CANCELLED
  OVERDUE
}

enum PaymentStatus {
  PAID
  PENDING
  FAILED
  REFUNDED
}

enum PaymentMethod {
  PIX
  CREDIT_CARD
}

model Cliente {
  id          Int           @id @default(autoincrement())
  email       String        @unique
  nome        String
  criado_em   DateTime      @default(now())
  cpf         String        @unique
  telefone    String        @unique
  assinaturas Assinatura[]
}

model Admin {
  id         Int      @id @default(autoincrement())
  avatar     String
  nome       String
  email      String   @unique
  senha      String
  criado_em  DateTime @default(now())
}

model Plano {
  id            Int          @id @default(autoincrement())
  banner        String
  nome          String       @unique
  descricao     String
  preco         Decimal      @db.Decimal(10, 2)
  status        PlanStatus   @default(ACTIVE)
  criado_em     DateTime     @default(now())
  atualizado_em DateTime     @updatedAt
  assinaturas   Assinatura[]
}

model Assinatura {
  id                    Int              @id @default(autoincrement())
  client_id             Int
  client                Cliente           @relation(fields: [client_id], references: [id])
  plano_id              Int
  plano                 Plano            @relation(fields: [plano_id], references: [id])
  status                SignatureStatus  @default(ACTIVE)
  data_inicio           DateTime         @default(now())
  data_ultimo_pagamento DateTime?
  proximo_vencimento    DateTime
  criado_em             DateTime         @default(now())
  atualizado_em         DateTime         @updatedAt
  pagamentos            Pagamento[]
}

model Pagamento {
  id             Int            @id @default(autoincrement())
  assinatura_id  Int
  assinatura     Assinatura     @relation(fields: [assinatura_id], references: [id])
  valor          Decimal        @db.Decimal(10, 2)
  status         PaymentStatus  @default(PENDING)
  metodo         PaymentMethod
  pago_em        DateTime?
  referencia_mes Int
  referencia_ano Int
  obs            String?
  criado_em      DateTime       @default(now())

  @@unique([assinatura_id, referencia_mes, referencia_ano])
}